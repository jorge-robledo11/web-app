{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/*.instructions.md"
  ],
  "command": {
    "improve-commits": {
      "agent": "improve-commits",
      "subtask": true,
      "model": "opencode-go/deepseek-v4-flash"
    },
    "changelog": {
      "agent": "changelog",
      "subtask": true,
      "model": "opencode-go/deepseek-v4-flash"
    }
  }
}