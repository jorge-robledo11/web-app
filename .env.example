# ============================================================
# PostgreSQL local (Docker)
# ============================================================
# La base de datos se ejecuta con Docker o Docker Compose.
# Una sola URL para runtime y migraciones con Alembic.
#
# Formato para asyncpg:
#   postgresql+asyncpg://<usuario>:<password>@<host>:<puerto>/<nombre>
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/realtor

# ============================================================
# App settings
# ============================================================
APP_ENV=development
LOG_LEVEL=INFO
